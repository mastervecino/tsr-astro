---
/**
 * 404.astro — Custom Not Found page
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — The Strategic Recruiter"
  description="This page doesn't exist. Find what you're looking for in the TSR insights archive."
>
  <section class="not-found" aria-labelledby="nf-heading">
    <div class="container">
      <span class="not-found-code" aria-hidden="true">404</span>
      <h1 id="nf-heading">This page doesn't exist.</h1>
      <p>
        Either the link is broken or this article hasn't been written yet.
        Either way — the insights archive is a better use of your time.
      </p>
      <div class="nf-actions">
        <a href="/blog" class="btn btn-primary">Read insights →</a>
        <a href="/"    class="btn btn-ghost">Go home</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    background: var(--deep-navy);
    min-height: 70vh;
    display: flex;
    align-items: center;
    color: var(--white);
    padding: var(--s10) 0;
    text-align: center;
  }
  .not-found-code {
    display: block;
    font-family: var(--serif);
    font-size: clamp(5rem, 15vw, 10rem);
    font-weight: 700;
    color: rgba(96,165,250,0.18);
    line-height: 1;
    margin-bottom: var(--s2);
  }
  .not-found h1 {
    color: var(--white);
    margin-bottom: var(--s3);
  }
  .not-found p {
    color: rgba(255,255,255,0.72);
    max-width: 460px;
    margin: 0 auto var(--s5);
  }
  .nf-actions {
    display: flex;
    gap: var(--s2);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
